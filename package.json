{
  "name": "smart-attendance-system",
  "version": "1.0.0",
  "description": "Facial Recognition Attendance System",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Ashish",
  "license": "MIT",
  "build": {
    "appId": "com.attendance.desktop",
